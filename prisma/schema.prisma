generator client {
  provider = "prisma-client-js"
}

model Order {
  id               Int      @id @default(autoincrement())
  namaPembeli      String
  tipePesanan      String
  statusPesanan    String
  hargaProduk      Int
  jumlahProduk     Int
  warnaProduk      String
  ketebalanAkrilik String
  keterangan       String?
  waktuPemesanan   DateTime
  terakhirUpdate   DateTime @updatedAt
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ROLE {
  KING
  ADMIN
  USER
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  image    String
  role     ROLE    @default(USER)

  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}